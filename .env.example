# Required — create an internal integration at https://www.notion.so/my-integrations
# and share your database with it (database page → ⋯ → Connections)
NOTION_API_KEY=ntn_your_integration_secret_here

# Required — the 32-char ID from your database URL:
# https://notion.so/workspace/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=your_database_id_here

# Optional — where post JSON files are written (default: content/posts)
# CONTENT_DIR=content/posts

# Optional — where downloaded images are saved (default: public/images/posts)
# IMAGES_DIR=public/images/posts

# Optional — URL prefix your site serves IMAGES_DIR under (default: /images/posts)
# IMAGES_PUBLIC_PATH=/images/posts

# Optional — override Notion database property names if your schema differs
# TITLE_PROPERTY=Title
# STATUS_PROPERTY=Status
# STATUS_PUBLISHED=Published
# DATE_PROPERTY=Published Date
# TAGS_PROPERTY=Tags
